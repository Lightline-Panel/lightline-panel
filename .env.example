# Lightline VPN Panel — Docker Compose Environment Variables
# Copy this file to .env and fill in the values

# ===== REQUIRED =====

# Your domain name (Caddy will auto-provision HTTPS via Let's Encrypt)
# Set to :80 for HTTP-only (no SSL) — but ssconf:// won't work without HTTPS
PANEL_DOMAIN=panel.example.com

# Server IP (for default node creation)
SERVER_IP=your-server-ip

# ===== Database =====
POSTGRES_PASSWORD=changeme

# ===== Security =====
# JWT secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-secret

# ===== Optional =====
# Shadowsocks port (default 8388)
SS_PORT=8388

# CORS origins (auto-includes https://PANEL_DOMAIN)
# CORS_ORIGINS=http://localhost,https://panel.example.com
