# Lightline VPN Panel — Docker Compose Environment Variables
# Copy this file to .env and fill in the values

# ===== REQUIRED =====

# Server IP (for default node creation)
SERVER_IP=your-server-ip

# ===== Database =====
POSTGRES_PASSWORD=changeme

# ===== Security =====
# JWT secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-secret

# ===== SSL / HTTPS (like Marzban) =====
# To enable HTTPS (required for ssconf:// subscription URLs):
# 1. Stop any service on port 80: docker compose down
# 2. Run: certbot certonly --standalone -d YOUR_DOMAIN
# 3. Set your domain below:
PANEL_DOMAIN=YOUR_DOMAIN
# The entrypoint auto-detects certs from /etc/letsencrypt/live/PANEL_DOMAIN/
# If no certs found, panel runs HTTP-only

# ===== Optional =====
# Shadowsocks port (default 8388)
SS_PORT=8388

# CORS origins
# CORS_ORIGINS=http://localhost,https://your-domain.com
