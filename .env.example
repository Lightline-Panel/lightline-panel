# Lightline VPN Panel — Docker Compose Environment Variables
# Copy this file to .env and fill in the values

# ===== REQUIRED =====

# Server IP (for default node creation)
SERVER_IP=your-server-ip

# ===== Database =====
POSTGRES_PASSWORD=changeme

# ===== Security =====
# JWT secret (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-secret

# ===== SSL / HTTPS =====
# To enable HTTPS (required for ssconf:// subscription URLs):
# 1. Run: certbot certonly --standalone -d YOUR_DOMAIN
# 2. Set the path to your cert directory:
SSL_CERT_DIR=/etc/letsencrypt/live/YOUR_DOMAIN
# The directory must contain fullchain.pem and privkey.pem
# If not set, panel runs HTTP-only (default: ./ssl empty directory)

# ===== Optional =====
# Shadowsocks port (default 8388)
SS_PORT=8388

# CORS origins
# CORS_ORIGINS=http://localhost,https://your-domain.com
