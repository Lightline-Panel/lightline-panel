# Lightline VPN Panel — Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL connection string (asyncpg)
POSTGRES_URL=postgresql+asyncpg://lightline:changeme@localhost:5432/lightline

# JWT secret key (generate: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET=change-me-to-a-random-secret-key

# Outline mode: 'mock' for development, 'live' for production
OUTLINE_MODE=mock

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# License server URL (optional, for external license validation)
# Point this to your Lightline License Server instance
# Example: https://license.yourdomain.com
LICENSE_SERVER_URL=

# License server request timeout in seconds (default: 10)
LICENSE_SERVER_TIMEOUT=10

# Redis URL (optional, for caching and rate limiting)
REDIS_URL=redis://localhost:6379/0
